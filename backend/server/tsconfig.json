{
  "compilerOptions": {
    /* =========================
       Project Structure
       ========================= */
    "rootDir": "./src",
    "outDir": "./dist",

    /* =========================
       JavaScript Target
       ========================= */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* =========================
       Node Types
       ========================= */
    "types": ["node"],

    /* =========================
       Type Checking
       ========================= */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* =========================
       Module Behavior
       ========================= */
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    /* =========================
       Interoperability
       ========================= */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* =========================
       Output & Debugging
       ========================= */
    "sourceMap": true,

    /* =========================
       Performance
       ========================= */
    "skipLibCheck": true,

    /* =========================
       Consistency
       ========================= */
    "forceConsistentCasingInFileNames": true
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}